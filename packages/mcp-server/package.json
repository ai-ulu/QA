{
  "name": "@autoqa/mcp-server",
  "version": "2.0.0",
  "description": "Change-aware Playwright maintenance copilot MCP server for AI coding clients",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js"
  },
  "bin": {
    "autoqa-mcp": "dist/cli.js"
  },
  "files": [
    "dist",
    "scripts/ci-impact.mjs",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "testing",
    "playwright",
    "ai",
    "ide",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-ulu/QA.git",
    "directory": "packages/mcp-server"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "dogfood": "node ./scripts/dogfood.mjs",
    "start": "node dist/index.js",
    "ci:impact": "node ./scripts/ci-impact.mjs --repo . --auto-base --format github",
    "prepack": "pnpm run build",
    "release:check": "pnpm run build && pnpm run test && npm pack --dry-run",
    "smoke": "node ./scripts/smoke-test.mjs",
    "test": "pnpm run build && pnpm run smoke"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "playwright": "^1.40.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
