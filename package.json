{
  "name": "autoqa-mcp-workspace",
  "version": "1.0.0",
  "description": "Lean workspace for the AutoQA MCP server",
  "private": true,
  "workspaces": [
    "packages/mcp-server"
  ],
  "scripts": {
    "start": "pnpm --filter @autoqa/mcp-server start",
    "dev": "pnpm --filter @autoqa/mcp-server dev",
    "build": "pnpm --filter @autoqa/mcp-server build",
    "test": "pnpm --filter @autoqa/mcp-server test",
    "ci:impact": "pnpm --filter @autoqa/mcp-server ci:impact",
    "dogfood": "pnpm --filter @autoqa/mcp-server dogfood",
    "release:check": "pnpm --filter @autoqa/mcp-server release:check",
    "smoke": "pnpm --filter @autoqa/mcp-server smoke",
    "clean": "Remove-Item -Recurse -Force .\\packages\\mcp-server\\dist -ErrorAction SilentlyContinue"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-ulu/QA.git"
  }
}
